# Copiá este archivo a `.env` en la **raíz del repo** (junto a docker-compose.yml).
# Docker Compose carga `.env` automáticamente para interpolar ${VAR} en el compose.
# El archivo `.env` real está en .gitignore: no lo subas al repositorio.

# --- Panel del sistema (super-admin, /system/login) ---
SYSTEM_ADMIN_PASSWORD=cambiar-clave-sistema-min-8-chars
# SYSTEM_ADMIN_EMAIL=admin@ejemplo.com

# --- Mercado Pago (obligatorias las dos para ver "Activar suscripción" en el panel) ---
# Ver guía: docs/mercadopago-guia-local.md
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Obligatorio si abrís el panel por ngrok (o cualquier URL que no sea localhost):
# MP sin esto arma back_url con CLIENT_ORIGIN → error "Invalid value for back_url".
# Ej.: ngrok http 5173 → copiá la URL https (sin path ni barra final).
# MP_REDIRECT_BASE_URL=https://xxxx.ngrok-free.dev

# Opcional (E2E / simular MP sin API real):
# MP_MOCK_PREAPPROVAL_STATUS=authorized

# Opcional: JWT más fuerte que el default del compose
# JWT_SECRET=al-menos-16-caracteres-aleatorios

# --- Producción (OCI / VPS + Docker + TLS) ---
# Plantilla: deploy/env.production.example · Guía: docs/deploy-oracle-free.md
# docker compose -f docker-compose.prod.yml up -d --build

# Ventana de cambio de precio (super-admin). Default en compose: 30. En local / pruebas
# usá 0 para aplicar el cambio en cuanto vence la fecha programada (sin esperar 30 días).
# PRICE_CHANGE_WINDOW_DAYS=0
