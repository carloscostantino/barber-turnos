# Copiar a la raíz del repo en la VM:  cp deploy/env.production.example .env
# Luego reemplazar COMPLETAR_* y contraseñas. Ver docs/deploy-oracle-free.md
#
# Admin shop: en producción SOLO vale ADMIN_PASSWORD_BCRYPT (no uses ADMIN_PASSWORD).
# El hash debe corresponder a la clave que elijas. En local Docker a veces usás admin12345;
# para la misma clave en prod: cd server && npm run hash-admin-password -- "admin12345"
# (pegá el hash en ADMIN_PASSWORD_BCRYPT; podés usar comillas simples: 'hash...' si hay $).

# --- Docker Compose / Caddy ---
CADDY_DOCKERFILE=Caddyfile.apex
PUBLIC_HOST=agendaonline.com.ar

# --- Dominio público (HTTPS, sin barra final en ORIGIN / REDIRECT) ---
CLIENT_ORIGIN=https://agendaonline.com.ar
VITE_API_BASE=https://agendaonline.com.ar/api
CORS_ALLOWED_ORIGINS=
MP_REDIRECT_BASE_URL=https://agendaonline.com.ar

# --- Base de datos (misma clave en POSTGRES_PASSWORD y en DATABASE_URL) ---
POSTGRES_DB=barber_turnos
POSTGRES_USER=barber
POSTGRES_PASSWORD=COMPLETAR_CLAVE_POSTGRES_SEGURA
DATABASE_URL=postgres://barber:COMPLETAR_CLAVE_POSTGRES_SEGURA@db:5432/barber_turnos

# --- API ---
JWT_SECRET=COMPLETAR_CADENA_SECRETA_MINIMO_16_CARACTERES
TIMEZONE=America/Argentina/Buenos_Aires
DEFAULT_SHOP_SLUG=default
ADMIN_PASSWORD_BCRYPT=$2b$10$8QzoPA/VIwkLoxS9rvJ9m.ICXRXdUMkmEgS/TldbTnl/HC4nTPjI.

# Super-admin /system/login — opcional. Descomentá y completá UNA de las dos formas:
# SYSTEM_ADMIN_PASSWORD=Minimo8CaracteresPlano
# SYSTEM_ADMIN_PASSWORD_BCRYPT=
# SYSTEM_ADMIN_EMAIL=admin@agendaonline.com.ar

# --- Mercado Pago (producción). Webhook: https://agendaonline.com.ar/api/webhooks/mercadopago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_SUBSCRIPTION_AMOUNT_ARS=4999
MP_SUBSCRIPTION_REASON=Suscripción Barber Turnos
PRICE_CHANGE_WINDOW_DAYS=30
# MP_MOCK_PREAPPROVAL_STATUS=   # solo E2E local; no uses en prod

# --- Email / recordatorios (opcional; si SMTP_HOST está vacío, el resto SMTP se ignora) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Barbería <noreply@agendaonline.com.ar>
REMINDER_HOURS_BEFORE=24
REMINDER_POLL_MINUTES=15

# --- Trial / jobs ---
TRIAL_DURATION_DAYS=14
TRIAL_WARNING_DAYS=3
TRIAL_JOB_HOURS=6

# --- Otros ---
# WHATSAPP_NUMBER=54911xxxxxxxx

# TRUST_PROXY lo fuerza docker-compose.prod.yml en el servicio api; no hace falta acá.
