DATABASE_URL=postgres://barber:barber@localhost:5432/barber_turnos
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
TIMEZONE=America/Argentina/Buenos_Aires
# Slug del shop para rutas legacy sin `/shops/:slug` (tras migración multi-tenant suele ser `default`).
DEFAULT_SHOP_SLUG=default

# Stripe (opcional; sin esto el webhook responde 501)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Price de suscripción mensual (Checkout tras /shops/register)
# STRIPE_PRICE_ID=price_...
# Solo dígitos: 54 + 9 + área + número (ej. 2664217899 → 5492664217899)
WHATSAPP_NUMBER=5492664217899

# Panel admin (obligatorios): login en POST /api/admin/login
JWT_SECRET=cambiar-por-al-menos-16-caracteres-seguros
# Definí exactamente UNA de las dos (no ambas):
# - Desarrollo local: contraseña en texto plano
ADMIN_PASSWORD=cambiar-clave-admin-min-8-chars
# - Producción: hash bcrypt (generar con: cd server && npm run hash-admin-password -- "tu-clave")
# ADMIN_PASSWORD_BCRYPT=$2b$10$...

# Panel del sistema (super-admin, opcional): habilita /system/login.
# Si no definís ninguna, el panel queda deshabilitado (503).
# - Desarrollo: contraseña en texto plano
# SYSTEM_ADMIN_PASSWORD=cambiar-clave-sistema-min-8-chars
# - Producción: hash bcrypt (misma utilidad: npm run hash-admin-password)
# SYSTEM_ADMIN_PASSWORD_BCRYPT=$2b$10$...
# Email del super-admin (display, opcional)
# SYSTEM_ADMIN_EMAIL=admin@ejemplo.com

# Recordatorios por email (opcional; si falta SMTP el servidor arranca igual)
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Barbería <info@dominio.com>"
# REMINDER_HOURS_BEFORE=24
# REMINDER_POLL_MINUTES=15
