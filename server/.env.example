DATABASE_URL=postgres://barber:barber@localhost:5432/barber_turnos
PORT=3001
CLIENT_ORIGIN=http://localhost:5173
# Orígenes extra para CORS (coma-separados). Con ngrok al 5173, agregá la URL https pública:
# CORS_ALLOWED_ORIGINS=https://xxxx.ngrok-free.dev
TIMEZONE=America/Argentina/Buenos_Aires
# Slug del shop para rutas legacy sin `/shops/:slug` (tras migración multi-tenant suele ser `default`).
DEFAULT_SHOP_SLUG=default

# Mercado Pago (opcional): sin MP_ACCESS_TOKEN el endpoint subscribe responde 501
# y el webhook rechaza firmas inválidas (no hay secret).
# MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Clave para firmar / verificar la cabecera `x-signature` de los webhooks de MP.
# MP_WEBHOOK_SECRET=cambiar-secret-webhook-mp
# Si MP devuelve "Invalid value for back_url", exponé el frontend (puerto 5173) con ngrok
# y definí la base pública https aquí (misma URL con la que abrís el admin después de pagar):
# MP_REDIRECT_BASE_URL=https://xxxx.ngrok-free.app
# Monto mensual en ARS (entero, sin centavos). Solo se usa como seed inicial de
# la tabla `platform_settings`; a partir del primer arranque la fuente de
# verdad es la DB y se edita desde el panel del super-admin.
# MP_SUBSCRIPTION_AMOUNT_ARS=4999
# Texto que MP muestra al cliente en el flujo de tarjeta. También se usa solo
# como seed inicial de la tabla `platform_settings`.
# MP_SUBSCRIPTION_REASON=Suscripción Barber Turnos
# Días de anticipación con los que se programa un cambio de precio desde el
# super-admin. El job aplica el cambio en MP al vencerse la ventana. En dev
# conviene bajarlo a 0 o 1 para probar el flujo sin esperar.
# PRICE_CHANGE_WINDOW_DAYS=30
# Solo E2E: fuerza el estado que devolvería MP sin llamar a la API real.
# Valores aceptados: authorized | paused | cancelled | pending.
# MP_MOCK_PREAPPROVAL_STATUS=

# Solo dígitos: 54 + 9 + área + número (ej. 2664217899 → 5492664217899)
WHATSAPP_NUMBER=5492664217899

# Panel admin (obligatorios): login en POST /api/admin/login
JWT_SECRET=cambiar-por-al-menos-16-caracteres-seguros
# Definí exactamente UNA de las dos (no ambas):
# - Desarrollo local: contraseña en texto plano
ADMIN_PASSWORD=cambiar-clave-admin-min-8-chars
# - Producción: hash bcrypt (generar con: cd server && npm run hash-admin-password -- "tu-clave")
# ADMIN_PASSWORD_BCRYPT=$2b$10$...

# Panel del sistema (super-admin, opcional): habilita /system/login.
# Si no definís ninguna, el panel queda deshabilitado (503).
# - Desarrollo: contraseña en texto plano
# SYSTEM_ADMIN_PASSWORD=cambiar-clave-sistema-min-8-chars
# - Producción: hash bcrypt (misma utilidad: npm run hash-admin-password)
# SYSTEM_ADMIN_PASSWORD_BCRYPT=$2b$10$...
# Email del super-admin (display, opcional)
# SYSTEM_ADMIN_EMAIL=admin@ejemplo.com

# Recordatorios por email (opcional; si falta SMTP el servidor arranca igual)
# SMTP_HOST=smtp.ejemplo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Barbería <info@dominio.com>"
# REMINDER_HOURS_BEFORE=24
# REMINDER_POLL_MINUTES=15

# Período de prueba de nuevas barberías (trial → suspended automático)
# Días desde el alta hasta que el trial vence.
# TRIAL_DURATION_DAYS=14
# Cuando quedan ≤ N días, se envía un email de aviso al owner (una sola vez).
# TRIAL_WARNING_DAYS=3
# Frecuencia del job que suspende trials vencidos y envía los avisos.
# TRIAL_JOB_HOURS=6
